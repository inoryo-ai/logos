{
  "name": "logos",
  "version": "0.0.1",
  "private": true,
  "description": "Centaurus Logos — business automation module platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @logos/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "workflow:health": "pnpm --filter @logos/web exec workflow health",
    "workflow:web": "pnpm --filter @logos/web exec workflow web"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  }
}
